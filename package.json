{
  "name": "rush-tracker",
  "version": "1.8.3",
  "main": "main.js",
  "scripts": {
    "start": "chcp 65001 > nul && electron .",
    "build": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rushtracker/app.git"
  },
  "build": {
    "appId": "com.rush.tracker",
    "productName": "rush-tracker",
    "afterPack": "./scripts/after-pack.js",
    "win": {
      "target": "portable",
      "artifactName": "${productName}.exe",
      "icon": "app.ico"
    },
    "extraResources": [
      {
        "from": "app.ico",
        "to": "app.ico"
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**"
    ],
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "fr"
    ],
    "removePackageScripts": true
  },
  "author": "lllab",
  "license": "GPL 3.0",
  "description": "minecraft rush statistics tracker",
  "devDependencies": {
    "@electron/asar": "^3.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "dotenv": "^17.3.1"
  }
}
